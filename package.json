{
  "name": "leakhunter",
  "version": "1.0.0",
  "private": true,
  "description": "LeakHunter - Revenue recovery system for New Jersey roofing companies",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm --workspace server run build && npm --workspace web run build",
    "test": "npm --workspace server run test",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "lint": "npm --workspace server run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
