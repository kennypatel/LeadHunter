# ---- Core ----
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
WEB_ORIGIN=http://localhost:5173
# Public web URL used in email unsubscribe links (defaults to WEB_ORIGIN).
PUBLIC_URL=http://localhost:5173
# Physical mailing address shown in the CAN-SPAM email footer (used when a
# company has no address on file). Required for compliant email outreach.
BUSINESS_ADDRESS=

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://leakhunter:leakhunter@localhost:5432/leakhunter?schema=public

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
COOKIE_NAME=lh_token

# ---- AI provider (mock | openai) ----
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---- Email provider (console | smtp) ----
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@leakhunter.app

# ---- SMS provider (console | twilio) ----
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ---- Safety ----
MAX_MESSAGES_PER_LEAD_PER_WEEK=3
# Live sending is ALSO gated by feature flags (live_sending / email_sending /
# sms_sending), all OFF by default. Even with real providers configured above,
# no message is sent until those flags are enabled in Admin > Feature flags.
# Twilio inbound STOP webhook: point your number's "A message comes in" URL to
#   https://<your-api-host>/api/webhooks/twilio/sms
